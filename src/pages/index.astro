---
// Sitenizdeki tüm markdown (.md) yayınlarını ana sayfa için de otomatik çeker
const posts = await Astro.glob('./*.md');
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());

const siteName = "RAUFAYAR.NET";
const siteUrl = "https://raufayar.net";
const description = "Kuantum Dijital İstihbarat Merkezi"; // Tam 4 kelime
---

<!doctype html>
<html lang="tr" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{siteName} | {description}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={siteUrl} />
		<meta name="robots" content="index, follow" />
		<link rel="preconnect" href="https://googleapis.com" />
		<link rel="preconnect" href="https://gstatic.com" crossorigin />
		<link href="https://googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-[#0B0F19] text-[#E2E8F0] font-sans antialiased">
		<header class="border-b border-[#1E293B] bg-[#0B0F19]/80 backdrop-blur-md sticky top-0 z-50">
			<div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="text-lg font-bold tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-[#00FF66] to-[#00E5FF]">
					{siteName}
				</a>
			</div>
		</header>

		<main class="max-w-4xl mx-auto px-6 py-12 space-y-16">
			<!-- ANA SAYFA HOŞ GELDİNİZ BÖLÜMÜ -->
			<div class="space-y-4">
				<h1 class="text-5xl font-extrabold tracking-tight text-white">
					{siteName}
				</h1>
				<p class="text-[#00FF66] text-xl font-mono tracking-wide">{description}</p>
			</div>

			<!-- OTOMATİK YAYIN LİSTESİ (BURAYA ASLA DOKUNMAYACAKSINIZ) -->
			<div class="border-t border-[#1E293B] pt-8">
				<h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
					<span class="w-2 h-2 rounded-full bg-[#00FF66] animate-pulse"></span>
					Son Yayınlar
				</h2>
				
				<div class="grid gap-6">
					{sortedPosts.length === 0 ? (
						<p class="text-[#64748B] italic">Henüz bir yayın bulunamadı.</p>
					) : (
						sortedPosts.map((post) => (
							<article class="group relative flex flex-col items-start p-6 rounded-2xl bg-[#111827]/50 border border-[#1E293B] hover:border-[#00FF66]/30 transition-all duration-300">
								<div class="text-xs text-[#64748B] mb-2 font-mono">
									{post.frontmatter.pubDate}
								</div>
								<h3 class="text-xl font-bold text-white group-hover:text-[#00FF66] transition-colors">
									<a href={post.url}>
										<span class="absolute -inset-y-0 -inset-x-0 z-20 rounded-2xl"></span>
										{post.frontmatter.title}
									</a>
								</h3>
								<p class="mt-2 text-sm text-[#94A3B8] line-clamp-2">
									{post.frontmatter.description}
								</p>
							</article>
						))
					)}
				</div>
			</div>
		</main>

		<footer class="border-t border-[#1E293B] mt-24 py-8 text-center text-xs text-[#64748B]">
			<p>© 2026 {siteName} — Tüm Hakları Saklıdır.</p>
		</footer>
	</body>
</html>

<style is:global>
	html { font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
</style>

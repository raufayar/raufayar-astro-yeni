<script is:inline>
    (function() {
        const basePopulation = 8328452140; 
        const startTime = new Date("2026-06-14T00:00:00Z").getTime();
        const birthsPerMilli = 4.3 / 1000;
        const deathsPerMilli = 1.9 / 1000;
        const attacksPerMilli = 45 / 1000;

        function runGlobalCalculators() {
            const now = Date.now();
            const elapsedMilli = now - startTime;
            if (elapsedMilli > 0) {
                document.getElementById("live-pop").innerText = Math.floor(basePopulation + (elapsedMilli * (birthsPerMilli - deathsPerMilli))).toLocaleString('en-US');
                document.getElementById("live-births").innerText = "+" + Math.floor(elapsedMilli * birthsPerMilli).toLocaleString('en-US');
                document.getElementById("live-deaths").innerText = "-" + Math.floor(elapsedMilli * deathsPerMilli).toLocaleString('en-US');
                document.getElementById("live-attacks").innerText = Math.floor(elapsedMilli * attacksPerMilli).toLocaleString('en-US');
            }
        }
        setInterval(runGlobalCalculators, 200);

        function runAtomClock() {
            const timeElement = document.getElementById("atom-time");
            const msElement = document.getElementById("atom-ms");
            if (!timeElement || !msElement) return;
            const now = new Date();
            timeElement.innerText = String(now.getHours()).padStart(2, '0') + ":" + String(now.getMinutes()).padStart(2, '0') + ":" + String(now.getSeconds()).padStart(2, '0');
            msElement.innerText = "." + String(now.getMilliseconds()).padStart(3, '0');
            window.requestAnimationFrame(runAtomClock);
        }
        window.requestAnimationFrame(runAtomClock);

        async function runGasTracker() {
            try {
                const response = await fetch('https://cloudflare-eth.com', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ jsonrpc: "2.0", method: "eth_gasPrice", params: [], id: 1 })
                });
                const data = await response.json();
                if (data && data.result) {
                    const gwei = Math.round(parseInt(data.result, 16) / 1000000000);
                    if (gwei > 0) {
                        document.getElementById("live-gas").innerText = gwei + " Gwei";
                        document.getElementById("gas-pulse").style.backgroundColor = gwei < 30 ? "#56d364" : (gwei < 70 ? "#ffaa00" : "#f85149");
                    }
                }
            } catch (e) {}
        }
        setInterval(runGasTracker, 20000); runGasTracker();

        async function runSystemPinger() {
            const targets = [
                { url: 'https://openai.com', pingId: 'ai-ping', pulseId: 'ai-status-pulse' },
                { url: 'https://github.com', pingId: 'git-ping', pulseId: 'git-status-pulse' }
            ];
            targets.forEach(async (target) => {
                try {
                    const t0 = performance.now();
                    await fetch(target.url, { mode: 'no-cors', cache: 'no-store' });
                    const ping = Math.round(performance.now() - t0);
                    document.getElementById(target.pingId).innerText = ping + " ms";
                    document.getElementById(target.pulseId).style.backgroundColor = "#56d364";
                } catch (e) {
                    document.getElementById(target.pingId).innerText = "ERROR";
                    document.getElementById(target.pulseId).style.backgroundColor = "#f85149";
                }
            });
        }
        setInterval(runSystemPinger, 30000); runSystemPinger();
    })();
</script>


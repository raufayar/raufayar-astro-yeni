---
// Sitenizdeki tüm markdown (.md) yayınlarını otomatik çeker
const posts = await Astro.glob('./*.md');
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());
const latestPosts = sortedPosts.slice(0, 5); // Maksimum 5 yazı ile sınırlama

const siteName = "RAUFAYAR.NET";
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Forum | Rauf Ayar</title>
    
    <!-- Google AdSense Otomatik Reklam Entegrasyonu -->
    <script async src="https://googlesyndication.com" crossorigin="anonymous"></script>

    <style>
        /* GitHub ve RaufAyar.net ruhuna uygun tam uyumlu karanlık tema */
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            background: #0d1117; 
            color: #c9d1d9; 
            padding: 2rem; 
            margin: 0;
        }
        .container { 
            max-width: 850px; 
            margin: 0 auto; 
            position: relative;
        }
        h1 { 
            color: #f0f6fc; 
            border-bottom: 1px solid #30363d; 
            padding-bottom: 1rem; 
            font-size: 2.2rem;
        }
        p { 
            color: #8b949e; 
            line-height: 1.6; 
            font-size: 1.1rem;
        }
        .notice {
            background: #161b22;
            border: 1px solid #30363d;
            border-left: 4px solid #58a6ff;
            padding: 1rem;
            border-radius: 6px;
            margin-bottom: 2rem;
        }

        /* 📁 TAM SOL TARAFTA DİKEY KATEGORİ LİSTESİ */
        .left-categories {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 10px;
            margin-top: 1.5rem;
            margin-bottom: 2.5rem;
            padding-left: 5px;
        }
        .category-link {
            color: #58a6ff;
            text-decoration: none;
            font-size: 1.05rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .category-link:hover {
            color: #79c0ff;
            text-decoration: underline;
        }

        /* ORİJİNAL YAPINIZI BOZMAYAN ASILI SAĞ PANEL CSS */
        @media (min-width: 1200px) {
            .sidebar-box {
                position: absolute;
                right: -320px;
                top: 80px;
                width: 260px;
                background: #161b22;
                border: 1px solid #30363d;
                border-radius: 6px;
                padding: 1rem;
            }
        }
        @media (max-width: 1199px) {
            .sidebar-box {
                background: #161b22;
                border: 1px solid #30363d;
                border-radius: 6px;
                padding: 1rem;
                margin-top: 2rem;
                margin-bottom: 2rem;
            }
        }
        
        h2.sidebar-title {
            color: #f0f6fc;
            font-size: 1.1rem;
            margin-top: 0;
            margin-bottom: 0.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid #30363d;
        }
        .mini-card {
            padding: 0.5rem 0;
            border-bottom: 1px solid #21262d;
            position: relative;
        }
        .mini-card:last-child {
            border-bottom: none;
            margin-bottom: 0.75rem;
        }
        .post-date {
            font-size: 0.75rem;
            color: #8b949e;
            font-family: monospace;
        }
        .post-title-link a {
            color: #58a6ff;
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 600;
        }
        .post-title-link a:hover {
            color: #79c0ff;
            text-decoration: underline;
        }
        .btn-archive {
            display: block;
            text-align: center;
            background: #21262d;
            color: #58a6ff;
            border: 1px solid #30363d;
            padding: 0.4rem;
            border-radius: 6px;
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 600;
        }
        .btn-archive:hover {
            background: #30363d;
            color: #c9d1d9;
        }
    </style>
</head>
<body>

    <!-- 1. SIRADA BU BUTON OLACAK -->
    <a href="https://raufayar.net" style="display: inline-flex; align-items: center; gap: 8px; background: #21262d; color: #c9d1d9; padding: 0.5rem 1rem; border-radius: 6px; border: 1px solid #30363d; text-decoration: none; font-size: 0.95rem; font-weight: 600; margin-bottom: 1.5rem;"> <span>🏠</span> Back to Home </a>

    <!-- Sizin Kendi Orijinal Konteyner Alanınız -->
    <div class="container">
        <h1>🌐 Global Open-Web Forum</h1>
        
        <div class="notice">
            <p><strong>Welcome to the decentralized discussion hub.</strong> This space is directly integrated with our GitHub Discussions. Share your insights, collaborate with global experts, and help us build an open web. Sign in with your GitHub account to participate.</p>
        </div>

        <!-- TAM SOLA YASLANMIŞ DİKEY ETİKETLER -->
        <div class="left-categories">
            <a href="/blog" class="category-link">🤖 AI</a>
            <a href="/blog" class="category-link">🎁 Ücretsiz Uygulamalar</a>
            <a href="/blog" class="category-link">📊 Analizler</a>
            <a href="/blog" class="category-link">🎯 Taktik ve Strateji</a>
            <a href="/blog" class="category-link">🚀 Gelecek</a>
            <a href="/blog" class="category-link">🌌 Kozmoz & Kuantum</a>
        </div>
        
        <!-- KRİTİK ALAN: Giscus yorumlarının yükleneceği hedef kutu -->
        <div class="giscus"></div>
        
        <!-- Çökmeyi Engelleyen Orijinal Giscus Scripti (is:inline modu aktif) -->
        <script is:inline src="https://giscus.app/client.js"
                data-repo="raufayar/raufayar.github.io"
                data-repo-id="R_kgDOS43ysQ"
                data-category="General"
                data-category-id="DIC_kwDOS43ysc4C_ECO"
                data-mapping="pathname"
                data-strict="0"
                data-reactions-enabled="1"
                data-emit-metadata="0"
                data-input-position="bottom"
                data-theme="dark_dimmed"
                data-lang="en"
                crossorigin="anonymous"
                async>
        </script>

        <!-- SAĞA ASILI YAN PANEL -->
        <div class="sidebar-box">
            <h2 class="sidebar-title">📡 Son Yayınlar</h2>
            
            {latestPosts.length === 0 ? (
                <p style="font-size: 0.85rem; color: #8b949e; font-style: italic;">Yayın bulunamadı.</p>
            ) : (
                latestPosts.map((post) => (
                    <div class="mini-card">
                        <div class="post-date">{post.frontmatter.pubDate}</div>
                        <div class="post-title-link">
                            <a href={post.url}>{post.frontmatter.title}</a>
                        </div>
                    </div>
                ))
            )}
            <a href="/blog" class="btn-archive" style="margin-top: 8px;">📂 Tüm Yayınları Gör ({posts.length})</a>
        </div>

    </div>

</body>
</html>

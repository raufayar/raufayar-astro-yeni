---
// Sitenizdeki tüm markdown (.md) yayınlarını otomatik çeker
const posts = await Astro.glob('./*.md');
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());
const latestPosts = sortedPosts.slice(0, 5); // Axiom: Maksimum 5 yazı ile sınırlama

const siteName = "RAUFAYAR.NET";
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Forum | Rauf Ayar</title>

    <!-- Google AdSense Otomatik Reklam Entegrasyonu -->
    <script async src="https://googlesyndication.com" crossorigin="anonymous"></script>

    <style>
        /* Sizin orijinal GitHub ve RaufAyar.net karanlık temanız */
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            background: #0d1117; 
            color: #c9d1d9; 
            padding: 2rem; 
            margin: 0;
        }
        .container { 
            max-width: 1150px; /* Yan panel için alanı genişlettik */
            margin: 0 auto; 
        }
        
        /* ÇALIŞAN İKİ SÜTUNLU PANEL YAPISI */
        .flex-layout {
            display: flex;
            gap: 2.5rem;
            margin-top: 1.5rem;
        }
        .left-forum {
            flex: 2.5;
            min-width: 0;
        }
        .right-sidebar {
            flex: 1;
            min-width: 260px;
            max-width: 300px;
        }

        h1 { 
            color: #f0f6fc; 
            border-bottom: 1px solid #30363d; 
            padding-bottom: 1rem; 
            font-size: 2.2rem;
            margin-top: 0;
        }
        h2.sidebar-title {
            color: #f0f6fc;
            font-size: 1.2rem;
            margin-top: 0;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid #30363d;
        }
        p { 
            color: #8b949e; 
            line-height: 1.6; 
            font-size: 1.1rem;
        }
        .notice {
            background: #161b22;
            border: 1px solid #30363d;
            border-left: 4px solid #58a6ff;
            padding: 1rem;
            border-radius: 6px;
            margin-bottom: 2rem;
        }

        /* Yan Panel Yayın Kartları */
        .sidebar-box {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 6px;
            padding: 1rem;
        }
        .mini-card {
            padding: 0.6rem 0;
            border-bottom: 1px solid #21262d;
            position: relative;
        }
        .mini-card:last-child {
            border-bottom: none;
        }
        .post-date {
            font-size: 0.75rem;
            color: #8b949e;
            font-family: monospace;
        }
        .post-title a {
            color: #58a6ff;
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 600;
            display: block;
            margin-top: 2px;
        }
        .post-title a::after {
            content: "";
            position: absolute;
            inset: 0;
        }
        .post-title a:hover {
            color: #79c0ff;
            text-decoration: underline;
        }

        /* Mobil görünüm ayarı */
        @media (max-width: 768px) {
            .flex-layout { flex-direction: column; }
            .right-sidebar { max-width: 100%; }
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- 1. SIRADA BU BUTON (Orijinal İstediğiniz Yer) -->
        <a href="https://raufayar.net" style="display: inline-flex; align-items: center; gap: 8px; background: #21262d; color: #c9d1d9; padding: 0.5rem 1rem; border-radius: 6px; border: 1px solid #30363d; text-decoration: none; font-size: 0.95rem; font-weight: 600; margin-bottom: 1.5rem;"> <span>🏠</span> Back to Home </a>

        <!-- Esnek İki Sütunlu Gövde -->
        <div class="flex-layout">
            
            <!-- SOL SÜTUN: Tamamen Sizin Orijinal Forum Yapınız -->
            <div class="left-forum">
                <h1>🌐 Global Open-Web Forum</h1>
                
                <div class="notice">
                    <p><strong>Welcome to the decentralized discussion hub.</strong> This space is directly integrated with our GitHub Discussions. Share your insights, collaborate with global experts, and help us build an open web. Sign in with your GitHub account to participate.</p>
                </div>
                
                <!-- KRİTİK ALAN: Giscus yorumlarının yükleneceği hedef kutu -->
                <div class="giscus"></div>
                
                <!-- Senin orijinal ve çalışan giscus kodun (Tam Yerinde) -->
                <script src="https://giscus.app/client.js"
                        data-repo="raufayar/raufayar.github.io"
                        data-repo-id="R_kgDOS43ysQ"
                        data-category="General"
                        data-category-id="DIC_kwDOS43ysc4C_ECO"
                        data-mapping="pathname"
                        data-strict="0"
                        data-reactions-enabled="1"
                        data-emit-metadata="0"
                        data-input-position="bottom"
                        data-theme="dark_dimmed"
                        data-lang="en"
                        crossorigin="anonymous"
                        async>
                </script>
            </div>

            <!-- SAĞ SÜTUN: Kibar ve Alan Kaplamayan Son Yayınlar Paneli -->
            <div class="right-sidebar">
                <div class="sidebar-box">
                    <h2 class="sidebar-title">📡 Son Yayınlar</h2>
                    
                    {latestPosts.length === 0 ? (
                        <p style="font-size: 0.9rem; color: #8b949e; font-style: italic;">Yayın bulunamadı.</p>
                    ) : (
                        latestPosts.map((post) => (
                            <div class="mini-card">
                                <div class="post-date">{post.frontmatter.pubDate}</div>
                                <div class="post-title">
                                    <a href={post.url}>{post.frontmatter.title}</a>
                                </div>
                            </div>
                        ))
                    )}
                </div>
            </div>

        </div> <!-- /flex-layout -->

    </div>

</body>
</html>

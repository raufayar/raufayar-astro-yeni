
---
// Sitenizdeki tüm markdown (.md) dosyalarını otomatik çeker
const allPosts = await Astro.glob('./*.md');

// 🛡️ YASAL SAYFALARI FİLTRELEME: Kurumsal dosyaların yayın listesini kirletmesini engeller
const filteredPosts = allPosts.filter(post => {
    const url = post.url || "";
    return !url.includes('faq') && 
           !url.includes('iletisim') && 
           !url.includes('hakkimda') && 
           !url.includes('gizlilik-ve-cerez-politikasi');
});

// Yayınları en yeni üstte olacak şekilde sıralar
const sortedPosts = filteredPosts.sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());
const latestPosts = sortedPosts.slice(0, 5); // Sağ panelde maksimum 5 gerçek yayın tutar

const siteName = "RAUFAYAR.NET";

---
// Layout dosyanızın bulunduğu yolu kontrol edin (örneğin ../layouts/MainLayout.astro)
import Layout from '../layouts/RealityEngine.astro';
import RealityEngine from '../components/RealityEngine.astro';
---

<Layout title="Gerçeklik Algoritması | Sistem Analizi">
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Gerçeklik Algoritması",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Web",
    "description": "Resmi rakamların ötesindeki gerçek çarpanı hesaplayan bir veri analiz aracı.",
    "publisher": {
      "@type": "Person",
      "name": "Rauf Ayar"
    }
  }
  </script>

  <main class="container mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-white mb-6">Gerçeklik Algoritması</h1>
    <p class="text-gray-400 mb-8">
      Resmi veriler, statükonun koruma kalkanıdır. Burası, o rakamların 
      gerçek hayattaki ağırlığını deşifre ettiğimiz yerdir.
    </p>
    
    <RealityEngine />
  </main>
</Layout>

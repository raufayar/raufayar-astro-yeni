---
// RealityEngine.astro
---
<div id="reality-engine" class="bg-black border border-amber-500 p-6 rounded-lg shadow-2xl max-w-2xl mx-auto my-10">
  <h2 class="text-amber-500 font-bold text-xl mb-4 uppercase tracking-widest">Sistem Gerçeklik Algoritması</h2>
  <p class="text-gray-400 text-sm mb-6">Resmi rakamların ötesindeki gerçekliği hesaplayın.</p>
  
  <div class="flex flex-col gap-4">
    <input 
      type="number" 
      id="input-val" 
      placeholder="Resmi veri veya fiyat girin..." 
      class="bg-gray-900 border border-gray-700 p-3 text-white rounded outline-none focus:border-amber-500 w-full"
    />
    <button 
      id="run-calc" 
      class="bg-amber-600 text-black font-bold py-3 rounded hover:bg-amber-500 transition-all cursor-pointer">
      GERÇEĞİ HESAPLA
    </button>
  </div>

  <div id="result" class="mt-6 hidden">
    <p class="text-gray-300">Sistemin söylediği: <span id="res-raw" class="font-bold"></span></p>
    <p class="text-amber-500 text-2xl font-black mt-2">Gerçek Çarpan: <span id="res-final"></span></p>
    <p id="aphorism" class="mt-4 italic text-gray-500 border-t border-gray-800 pt-4"></p>
  </div>
</div>

<script>
  const runBtn = document.getElementById('run-calc');
  const input = document.getElementById('input-val') as HTMLInputElement;
  const resultDiv = document.getElementById('result');

  runBtn?.addEventListener('click', () => {
    const val = parseFloat(input.value);
    if (isNaN(val)) return;
    const multiplier = 2.4; 
    const final = (val * multiplier).toFixed(2);
    document.getElementById('res-raw')!.innerText = val.toString();
    document.getElementById('res-final')!.innerText = final;
    document.getElementById('aphorism')!.innerText = "Statüko, hesap makinesini kendi lehine kalibre eder. Gerçek, o kalibrasyonun dışındadır.";
    resultDiv?.classList.remove('hidden');
  });
</script>
